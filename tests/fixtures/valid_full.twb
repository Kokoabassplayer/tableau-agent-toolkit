<?xml version='1.0' encoding='utf-8'?>
<workbook source-build='0.0.0 (0000.0.0.0.0)' source-platform='win' original-version='26.1' version='26.1' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <document-format-change-manifest>
    <ManifestByVersion />
  </document-format-change-manifest>
  <datasources>
    <datasource caption='SalesData' inline='true' name='SalesData' version='26.1'>
      <column name='Amount' datatype='float' role='measure' />
      <column name='Revenue' datatype='real' role='measure'>
        <calculation formula='SUM([Amount])' class='tableau' />
      </column>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='SalesChart' />
    <worksheet name='RevenueTable' />
  </worksheets>
  <dashboards>
    <dashboard name='Overview'>
      <zones>
        <zone name='SalesChart' />
        <zone name='RevenueTable' />
      </zones>
    </dashboard>
  </dashboards>
</workbook>
